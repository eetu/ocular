{
  "name": "ocular-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check src",
    "format:fix": "prettier --write src",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "validate": "yarn typecheck && yarn lint && yarn format",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.4",
    "eslint": "^10.4.0",
    "eslint-config": "github:eetu/eslint-config#v2.1.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.0.1",
    "svelte": "^5.56.3",
    "svelte-check": "^4.1.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  },
  "packageManager": "yarn@4.16.0",
  "dependencies": {
    "@lucide/svelte": "^1.17.0"
  }
}
